# ─────────────────────────────────────────────────────────────────────────────
# Kopanow Backend — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── PostgreSQL (required) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Firebase Admin — FCM device commands (required for lock/unlock) ───────────
# Option A (recommended for cloud): paste the entire service account JSON as one line:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id","private_key_id":"your_key_id","private_key":"-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n","client_email":"your_service_account@your_project_id.iam.gserviceaccount.com","client_id":"your_client_id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/your_service_account%40your_project_id.iam.gserviceaccount.com"}
# Option B (local dev only): path to downloaded service account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ── Admin Authentication (required) ───────────────────────────────────────────
# Sent as x-admin-key header from admin/loanoverview browser UIs:
ADMIN_KEY=your_strong_admin_key_here
# Optional separate key for loanoverview dashboard (falls back to ADMIN_KEY):
# LOANOVERVIEW_ADMIN_KEY=your_loanoverview_key_here
# Optional separate key for accounting API (falls back to ADMIN_KEY):
ACCOUNTING_API_SECRET=your_accounting_api_secret_here

# ── Lipa / Collections Dashboard ──────────────────────────────────────────────
# Default M-Pesa Lipa till number shown in /collections dashboard:
KOPANOW_LIPA_TILL=your_lipa_till_number_here
# Optional: filter till_contract_name ILIKE this substring (default: ELEGANSKY):
# KOPANOW_LIPA_TILL_CONTRACT_SUBSTRING=ELEGANSKY
# If 1, collections Lipa uses till_number column only (strict match):
# KOPANOW_LIPA_COLLECTIONS_STRICT_TILL_ONLY=0
# If 1, broad Lipa match omits till_contract_name ILIKE filter:
# KOPANOW_LIPA_COLLECTIONS_NO_CONTRACT_FILTER=0
# If 1, broad Lipa match omits Mixx SMS marker filters:
# KOPANOW_LIPA_COLLECTIONS_SKIP_MIXX_SMS_MARKERS=0
# Timezone for scheduled invoice processing (default: Africa/Dar_es_Salaam):
# KOPANOW_SCHEDULED_INVOICE_TZ=Africa/Dar_es_Salaam

# ── Lipa Ingest ───────────────────────────────────────────────────────────────
# Secret for POST /api/lipa/transactions (sent as x-lipa-secret header):
LIPA_INGEST_SECRET=your_lipa_ingest_secret_here
# If 1, raw_sms or sms_concatenated_body is required and Mixx markers are validated:
# LIPA_INGEST_REQUIRE_MIXX_MARKERS=0

# ── Android App Version Gate ──────────────────────────────────────────────────
# Minimum Android app versionCode allowed for enrollment and device registration:
MIN_SUPPORTED_VERSION_CODE=6

# ── APK Provisioning ──────────────────────────────────────────────────────────
# Publicly accessible URL where Android phones download the Kopanow APK during provisioning:
APK_DOWNLOAD_URL=https://your-domain.com/kopanow.apk
# SHA-256 of the APK in base64url format (no padding) — required for QR provisioning:
APK_SHA256_BASE64URL=your_apk_sha256_base64url_checksum_here

# ── PIN Encryption ────────────────────────────────────────────────────────────
# 32-char key used to encrypt system PINs at rest (generate a strong random secret):
PIN_ENCRYPTION_KEY=your_32_character_encryption_key_here!!

# ── Africa's Talking — SMS (required for SMS notifications) ──────────────────
# Use 'sandbox' for testing, your real username for production:
AT_USERNAME=your_africastalking_username_here
AT_API_KEY=your_africastalking_api_key_here
# Optional sender ID (leave blank to use short-code):
# AT_SENDER_ID=Kopanow

# ── AzamPay — Mobile Money Checkout (Tanzania) ───────────────────────────────
# Set AZAMPAY_SANDBOX=false for production:
AZAMPAY_SANDBOX=false
AZAMPAY_APP_NAME=your_azampay_app_name_here
AZAMPAY_CLIENT_ID=your_azampay_client_id_here
AZAMPAY_CLIENT_SECRET=your_azampay_client_secret_here
AZAMPAY_API_KEY=your_azampay_api_key_here
# Default payment provider (Mpesa, Airtel, Tigo, etc.):
# AZAMPAY_DEFAULT_PROVIDER=Mpesa
# Override AzamPay URLs (optional — auto-set from AZAMPAY_SANDBOX):
# AZAMPAY_AUTH_URL=https://authenticator.azampay.co.tz/AppRegistration/GenerateToken
# AZAMPAY_CHECKOUT_BASE=https://checkout.azampay.co.tz

# ── Anthropic API — AI Phone Price Lookup (optional) ─────────────────────────
# Required only for the AI-powered mkopo device phone price feature:
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Mkopo Device Catalog ──────────────────────────────────────────────────────
# URL to download device_mkopo.json if not present in the data/ directory:
# MKOPO_CATALOG_URL=https://raw.githubusercontent.com/savcom1/kopanow-backend/android/app/src/main/assets/device_mkopo.json
